{
	"name": "sahne-js",
	"version": "2.0.0",
	"description": "SahneJs is a CLI tool designed for mocking, testing, and debugging by intercepting and manipulating requests. It leverages Puppeteer's interceptor to capture and manipulate specific requests. You can direct these requests to an internal development server or read them from a local file.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kerematam/sahne-js.git",
		"directory": "packages/sahne"
	},
	"keywords": [
		"mocking",
		"testing",
		"debugging",
		"Puppeteer",
		"interceptor",
		"interception"
	],
	"scripts": {
		"prebuild": "rm -rf ./dist",
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x ./dist/cli.js",
		"typecheck": "tsc --noEmit"
	},
	"author": "Kerem Atam",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22.18.0"
	},
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"devDependencies": {
		"@types/node": "^24.13.3",
		"puppeteer": "^25.3.0",
		"typescript": "^5.9.3"
	},
	"bin": {
		"sahne": "./dist/cli.js"
	},
	"peerDependencies": {
		"puppeteer": "^20.0.0 || ^21.0.0 || ^22.0.0 || ^23.0.0 || ^24.0.0 || ^25.0.0"
	},
	"dependencies": {
		"commander": "^15.0.0"
	}
}
