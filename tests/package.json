{
	"name": "tests",
	"version": "1.0.0",
	"description": "",
	"scripts": {
		"server-run:dev-app": "npm run dev --workspace vite-dev-app",
		"server-run:prod-app": "npm run server --workspace vite-dev-app",
		"test-run:cli-features": "npm run test:cli-features --workspace sahne-app",
		"test-run:api-features": "npm run test --workspace sahne-app",
		"test:run": "concurrently --kill-others-on-fail \"npm run test-run:cli-features\" \"npm run test-run:api-features\"",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"pretest": "npm run build --prefix ../packages/sahne && npm run build --workspace vite-dev-app",
		"test": "start-test server-run:dev-app http://localhost:5173 server-run:prod-app http://localhost:8080 test:run"
	},
	"workspaces": [
		"sahne-app",
		"vite-dev-app"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"concurrently": "^10.0.3",
		"express": "^5.2.1",
		"start-server-and-test": "^3.0.11"
	}
}
